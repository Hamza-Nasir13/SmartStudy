{
  "name": "smartstudy-mvp",
  "version": "1.0.0",
  "description": "AI Smart Study App - Complete MVP for VC pitch",
  "private": true,
  "scripts": {
    "setup": "bash SETUP.sh",
    "install-all": "cd backend && npm install && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "react-scripts start",
    "start:backend": "cd backend && npm start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "keywords": [
    "education",
    "study",
    "quizzes",
    "flashcards",
    "ai",
    "edtech",
    "mvp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "concurrently": "^8.2.1"
  },
  "proxy": "http://localhost:5000",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
